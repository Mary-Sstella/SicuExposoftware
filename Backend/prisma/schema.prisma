generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model actividades {
  id_actividad Int       @id @default(autoincrement())
  tipo         String    @db.VarChar(50)
  descripcion  String
  id_usuario   Int?
  fecha        DateTime  @default(now()) @db.Timestamp(6)
  usuarios     usuarios? @relation(fields: [id_usuario], references: [id_usuario], onUpdate: NoAction)
}

model configuracion_turnos {
  id_configuracion Int     @id @default(autoincrement())
  hora_inicio      String  @db.VarChar(5)
  hora_fin         String  @db.VarChar(5)
  capacidad_maxima Int     @default(10)
  activo           Boolean @default(true)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model estudiante {
  id_estudiante          Int                  @id @default(autoincrement())
  numero_identificacion  BigInt?              @unique
  tipo_identificacion    tipo_id_enum?
  nombres                String?              @db.VarChar(100)
  apellidos              String?              @db.VarChar(100)
  correo_personal        String?              @db.VarChar(150)
  correo_institucional   String?              @db.VarChar(150)
  programa               String?              @db.VarChar(150)
  estado                 String               @default("ACTIVO") @db.VarChar(10)
  contador_inasistencias Int                  @default(0)
  limite_inasistencias   Int                  @default(3)
  fecha_registro         DateTime             @default(now()) @db.Timestamp(6)
  huellas                huellas[]
  notificaciones         notificaciones[]
  pagos                  pagos[]
  push_suscripciones     push_suscripciones[]
  qr_generados           qr_generados[]
  resenas                resenas[]
  reservas               reservas[]
  soporte                soporte[]
  usuarios               usuarios[]
}

model qr_generados {
  id_qr            Int         @id @default(autoincrement())
  id_reserva       Int?
  id_estudiante    Int?
  codigo_qr        String?     @db.VarChar(100)
  url_qr           String?     @db.VarChar(500)
  fecha_generacion DateTime?   @default(now()) @db.Timestamp(6)
  valido_hasta     DateTime?   @db.Timestamp(6)
  usado            Boolean?    @default(false)
  estudiante       estudiante? @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: NoAction, onUpdate: NoAction)
  reservas         reservas?   @relation(fields: [id_reserva], references: [id_reserva], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reservas {
  id_reserva            Int                 @id @default(autoincrement())
  id_estudiante         Int
  fecha                 DateTime?           @db.Date
  hora_inicio           String?             @db.VarChar(10)
  hora_fin              String?             @db.VarChar(10)
  lunes                 Boolean?
  martes                Boolean?
  miercoles             Boolean?
  jueves                Boolean?
  viernes               Boolean?
  estado                estado_reserva_enum @default(PENDIENTE)
  codigo_reserva        String?             @db.VarChar(50)
  numero_identificacion BigInt?
  nombre_estudiante     String?             @db.VarChar(100)
  numero_turno          Int?
  codigo_comprobante    String?             @db.VarChar(50)
  qr_generado           dia_enum?
  url_qr                String?             @db.VarChar(500)
  fecha_generacion_qr   DateTime?           @db.Date
  qr_valido_hasta       DateTime?           @db.Date
  id_comprobante        Int?
  metodo                String?             @default("MANUAL") @db.VarChar(10)
  qr_generados          qr_generados[]
  estudiante            estudiante          @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_estudiante], map: "idx_reservas_estudiante")
  @@index([fecha], map: "idx_reservas_fecha")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model usuarios {
  id_usuario               Int                        @id @default(autoincrement())
  username                 String?                    @unique @db.VarChar(60)
  email                    String?                    @unique @db.VarChar(150)
  password_hash            String                     @db.VarChar(255)
  rol                      tipo_rol_enum
  id_estudiante            Int?
  activo                   Boolean                    @default(true)
  fecha_creacion           DateTime                   @default(now()) @db.Timestamp(6)
  ultimo_acceso            DateTime?                  @db.Timestamp(6)
  actividades              actividades[]
  configuracion_formulario configuracion_formulario[]
  menu                     menu[]
  estudiante               estudiante?                @relation(fields: [id_estudiante], references: [id_estudiante], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model soporte {
  id_soporte      Int         @id @default(autoincrement())
  id_estudiante   Int?
  asunto          String      @db.VarChar(100)
  descripcion     String
  estado          String      @default("PENDIENTE") @db.VarChar(20)
  respuesta       String?
  fecha_creacion  DateTime    @default(now()) @db.Timestamp(6)
  fecha_respuesta DateTime?   @db.Timestamp(6)
  nombre          String?     @db.VarChar(100)
  correo          String?     @db.VarChar(150)
  archivo_url     String?     @db.VarChar(500)
  estudiante      estudiante? @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model resenas {
  id_rese_a      Int        @id(map: "reseñas_pkey") @default(autoincrement()) @map("id_reseña")
  id_estudiante  Int
  calificacion   Int
  texto          String
  fecha_creacion DateTime   @default(now()) @db.Timestamp(6)
  publicado      Boolean    @default(false)
  estudiante     estudiante @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade, onUpdate: NoAction, map: "reseñas_id_estudiante_fkey")
}

model inscripciones {
  id_inscripcion       Int      @id @default(autoincrement())
  nombre               String   @db.VarChar(100)
  apellidos            String   @db.VarChar(100)
  correo_institucional String   @db.VarChar(150)
  correo_personal      String?  @db.VarChar(150)
  cedula               String   @unique @db.VarChar(20)
  sisben_pdf           String   @db.VarChar(500)
  cedula_pdf           String   @db.VarChar(500)
  dias_semana          String   @db.VarChar(100)
  medio_transporte     String   @db.VarChar(50)
  lugar_origen         String   @db.VarChar(100)
  lugar_residencia     String   @db.VarChar(100)
  genero               String   @db.VarChar(20)
  ocupacion_padres     String   @db.VarChar(100)
  estado               String   @default("PENDIENTE") @db.VarChar(20)
  fecha_solicitud      DateTime @default(now()) @db.Timestamp(6)
  carrera              String   @default("Sin asignar") @db.VarChar(150)
}

model configuracion_formulario {
  id                 Int       @id @default(autoincrement())
  activo             Boolean   @default(false)
  fecha_inicio       DateTime? @db.Timestamp(6)
  fecha_fin          DateTime? @db.Timestamp(6)
  actualizado_por    Int?
  actualizado_en     DateTime  @default(now()) @db.Timestamp(6)
  cupo_lunes         Int       @default(0)
  cupo_martes        Int       @default(0)
  cupo_miercoles     Int       @default(0)
  cupo_jueves        Int       @default(0)
  cupo_viernes       Int       @default(0)
  fecha_fin_semestre DateTime? @db.Timestamp(6)
  precio_comida      Decimal   @default(0) @db.Decimal(10, 2)
  usuarios           usuarios? @relation(fields: [actualizado_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pagos {
  id_pago            Int        @id @default(autoincrement())
  id_estudiante      Int
  tipo_periodo       String     @db.VarChar(10)
  dias_pagados       Json
  cantidad_almuerzos Int
  almuerzos_usados   Int        @default(0)
  estado             String     @default("PENDIENTE") @db.VarChar(20)
  pdf_url            String     @db.VarChar(500)
  observacion        String?
  fecha_subida       DateTime   @default(now()) @db.Timestamp(6)
  fecha_revision     DateTime?  @db.Timestamp(6)
  codigo_qr          String?    @db.VarChar(1000)
  url_qr             String?    @db.VarChar(1000)
  monto_estudiante   Decimal?   @db.Decimal(10, 2)
  subtotal_sistema   Decimal?   @db.Decimal(10, 2)
  estudiante         estudiante @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade, onUpdate: NoAction)
}

model huellas {
  id_huella      Int        @id @default(autoincrement())
  id_estudiante  Int
  finger_id      Int        @unique
  fecha_registro DateTime?  @default(now()) @db.Timestamp(6)
  estudiante     estudiante @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade, onUpdate: NoAction, map: "fk_huella_estudiante")
}

model menu {
  id_menu      Int       @id @default(autoincrement())
  archivo_url  String    @db.VarChar(500)
  tipo_archivo String    @db.VarChar(10)
  subido_por   Int?
  fecha_subida DateTime  @default(now()) @db.Timestamp(6)
  usuarios     usuarios? @relation(fields: [subido_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
}

model notificaciones {
  id_notificacion Int        @id @default(autoincrement())
  id_estudiante   Int
  tipo            String     @db.VarChar(50)
  titulo          String     @db.VarChar(150)
  mensaje         String
  leida           Boolean    @default(false)
  fecha_creacion  DateTime   @default(now()) @db.Timestamp(6)
  estudiante      estudiante @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade, onUpdate: NoAction)
}

model push_suscripciones {
  id             Int        @id @default(autoincrement())
  id_estudiante  Int
  endpoint       String     @db.VarChar(500)
  p256dh         String     @db.VarChar(200)
  auth           String     @db.VarChar(100)
  fecha_creacion DateTime   @default(now()) @db.Timestamp(6)
  estudiante     estudiante @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade, onUpdate: NoAction)

  @@unique([id_estudiante, endpoint])
}

enum dia_enum {
  SI
  NO
}

enum estado_cartera_enum {
  PENDIENTE
  PAGADO
}

enum estado_reserva_enum {
  PENDIENTE
  ENTREGADA
  CANCELADA
}

enum tipo_id_enum {
  TI
  CC
  CE
}

enum tipo_rol_enum {
  ADMIN
  AUXILIAR_COMEDOR
  ESTUDIANTE
  REVISOR_PAGOS
}
